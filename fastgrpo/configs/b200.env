# Shared B200 defaults for the cloned FastGRPO repo.
# The train-time shape mirrors flashgrpo_b200/train.sh: effective prompt batch
# 16 * 2 = 32, max_training_token=8192, padding gap=1024, and generation repeat=8.

MODEL="${MODEL:-$WORKSPACE/models/Qwen2.5-7B-Instruct}"
MODEL_TYPE="${MODEL_TYPE:-qwen2}"
MODEL_DTYPE="${MODEL_DTYPE:-bf16}"
ATTN_IMPLEMENTATION="${ATTN_IMPLEMENTATION:-flash_attention_2}"

TRAIN_OPTION="${TRAIN_OPTION:-simplelr_abel_level3to5}"
TRAIN_DATA_FRACTION="${TRAIN_DATA_FRACTION:-0.4}"
TRAIN_SUBSET_SEED="${TRAIN_SUBSET_SEED:-42}"
MAX_TRAIN_SAMPLES="${MAX_TRAIN_SAMPLES:-0}"

DRAFT_DATASET="${DRAFT_DATASET:-$WORKSPACE/data/sharegpt/ShareGPT_V4.3_unfiltered_cleaned_split.json}"
DRAFT_EXP="${DRAFT_EXP:-fastgrpo_b200_draft_sharegpt_qwen25_7b}"
DRAFT_LOG_DIR="${DRAFT_LOG_DIR:-logs/fastgrpo_b200/$DRAFT_EXP}"
DRAFT_SAVED_MODEL_DIR="${DRAFT_SAVED_MODEL_DIR:-outputs/$DRAFT_EXP}"
DRAFT_CHECKPOINT_DIR="${DRAFT_CHECKPOINT_DIR:-outputs/$DRAFT_EXP/checkpoints}"

DRAFT_PRETRAIN_BATCH_SIZE="${DRAFT_PRETRAIN_BATCH_SIZE:-4}"
DRAFT_PRETRAIN_ACCUMULATION_STEPS="${DRAFT_PRETRAIN_ACCUMULATION_STEPS:-4}"
DRAFT_PRETRAIN_EPOCHS="${DRAFT_PRETRAIN_EPOCHS:-1}"
DRAFT_PRETRAIN_LR="${DRAFT_PRETRAIN_LR:-5e-5}"
DRAFT_PRETRAIN_WARMUP_RATIO="${DRAFT_PRETRAIN_WARMUP_RATIO:-0.05}"
DRAFT_PRETRAIN_MAX_SEQ_LEN="${DRAFT_PRETRAIN_MAX_SEQ_LEN:-1024}"
DRAFT_SAVE_CHECKPOINT_STEPS="${DRAFT_SAVE_CHECKPOINT_STEPS:-500}"

FASTGRPO_EXP="${FASTGRPO_EXP:-fastgrpo_b200_qwen25_7b}"
FASTGRPO_LOG_FILE="${FASTGRPO_LOG_FILE:-logs/fastgrpo_b200/$FASTGRPO_EXP/train.log}"
FASTGRPO_SAVED_MODEL_DIR="${FASTGRPO_SAVED_MODEL_DIR:-outputs/$FASTGRPO_EXP/target_lora}"
FASTGRPO_SAVED_DRAFT_MODEL_DIR="${FASTGRPO_SAVED_DRAFT_MODEL_DIR:-outputs/$FASTGRPO_EXP/draft_model}"
FASTGRPO_SAVED_STATISTICS_DIR="${FASTGRPO_SAVED_STATISTICS_DIR:-outputs/$FASTGRPO_EXP/statistics}"
FASTGRPO_CHECKPOINT_DIR="${FASTGRPO_CHECKPOINT_DIR:-outputs/$FASTGRPO_EXP/checkpoints}"
FASTGRPO_SAVE_CHECKPOINT_STEPS="${FASTGRPO_SAVE_CHECKPOINT_STEPS:-10}"
KEEP_LAST_CHECKPOINTS="${KEEP_LAST_CHECKPOINTS:-3}"
RESUME_CHECKPOINT="${RESUME_CHECKPOINT:-}"

BATCH_SIZE="${BATCH_SIZE:-16}"
ACCUMULATION_STEPS="${ACCUMULATION_STEPS:-2}"
DRAFT_ACCUMULATION_STEPS="${DRAFT_ACCUMULATION_STEPS:-1}"
MAX_TRAINING_TOKEN="${MAX_TRAINING_TOKEN:-8192}"
MAX_TRAINING_PADDING_GAP="${MAX_TRAINING_PADDING_GAP:-1024}"

GEN_MAX_LENGTH="${GEN_MAX_LENGTH:-2048}"
REPEATED_GENERATE_NUMS="${REPEATED_GENERATE_NUMS:-8}"
TEMPERATURE="${TEMPERATURE:-1.0}"
TOP_P="${TOP_P:-0.95}"
GRPO_ITERATION_NUM="${GRPO_ITERATION_NUM:-1}"
SAMPLE_NUM="${SAMPLE_NUM:-100}"
NUM_EPOCHS="${NUM_EPOCHS:-1}"

TARGET_LR="${TARGET_LR:-1e-6}"
FASTGRPO_DRAFT_LR="${FASTGRPO_DRAFT_LR:-1e-4}"
BETA="${BETA:-0.04}"
EPSILON="${EPSILON:-0.1}"
LOAD_LORA_PATH="${LOAD_LORA_PATH:-}"
IS_TRAIN_DRAFT="${IS_TRAIN_DRAFT:-True}"

# FastGRPO speculative_generate equivalents of flashgrpo_b200 tree budget.
VERIFICATION_CAPACITY="${VERIFICATION_CAPACITY:-768}"
MAX_VERIFICATION_NUM="${MAX_VERIFICATION_NUM:-768}"
MAX_DRAFT_TOKEN_LENGTH="${MAX_DRAFT_TOKEN_LENGTH:-5}"
MAX_DRAFT_K="${MAX_DRAFT_K:-8}"
MIN_DRAFT_TOKEN_LENGTH="${MIN_DRAFT_TOKEN_LENGTH:-3}"
DRAFT_TOKEN_LENGTH_C="${DRAFT_TOKEN_LENGTH_C:-0.75}"

NUM_WORKERS="${NUM_WORKERS:-8}"
PERSISTENT_WORKERS="${PERSISTENT_WORKERS:-true}"
